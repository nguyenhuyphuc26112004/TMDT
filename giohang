        if (isset($_SESSION['viewed_history']) && !empty($_SESSION['viewed_history'])) {
            $latest_id = $_SESSION['viewed_history'][0];
            
            // Lấy loại sản phẩm xem gần nhất
            $sql_type = "SELECT loai FROM san_pham WHERE id = $latest_id";
            $res_type = mysqli_query($con, $sql_type);
            
            if ($res_type && mysqli_num_rows($res_type) > 0) {
                $row_type = mysqli_fetch_assoc($res_type);
                $current_loai = $row_type['loai'];
                $history_ids = implode(',', $_SESSION['viewed_history']);

                // Truy vấn AI
                // Lấy sản phẩm cùng loại lên trước, sau đó là các sản phẩm ngẫu nhiên khác
            $sql_ai = "SELECT * FROM san_pham 
                    WHERE id NOT IN ($history_ids) 
                    AND trang_thai = 1 
                    ORDER BY (loai = '$current_loai') DESC, RAND() 
                    LIMIT 8";
                $res_display = mysqli_query($con, $sql_ai);

                if ($res_display && mysqli_num_rows($res_display) > 0) {
                    $title = '<i class="fa-solid fa-wand-magic-sparkles"></i> Dành riêng cho bạn';
                    $show_ai = true;
                }
            }
        }

        // THỨ TỰ ƯU TIÊN 2: NẾU KHÔNG CÓ AI -> HIỆN SẢN PHẨM MỚI NHẤT (DỰ PHÒNG)
        if (!$show_ai) {
            $title = '<i class="fa-solid fa-fire"></i> Sản phẩm mới nhất';
            $sql_new = "SELECT * FROM san_pham WHERE trang_thai = 1 ORDER BY id DESC LIMIT 4";
