    <script>
    // Biến lưu trữ ID giỏ hàng từ PHP để JS sử dụng
    const currentCartId = <?php echo $gioHang ? $gioHang['id'] : 'null'; ?>;

    document.addEventListener("DOMContentLoaded", function() {
        if (currentCartId) loadCart();
    });

    function loadCart() {
        fetch('api_get_cart.php')
            .then(res => res.json())
            .then(result => {
                if (result.status === 'success') {
                    renderCart(result.data, result.tongCong);
                } else {
                    document.getElementById('cart-table-body').innerHTML = 
                        `<tr><td colspan="5" style="text-align: center; color: red;">${result.message}</td></tr>`;
                }
            })
            .catch(err => console.error("Lỗi tải giỏ hàng:", err));
    }

    function renderCart(items, total) {
        const tableBody = document.getElementById('cart-table-body');
        const totalDisplay = document.getElementById('total-price-display');
        
        if (items.length === 0) {
            // Nếu xóa hết sản phẩm, hiển thị giao diện trống
            document.getElementById('cart-content').innerHTML = `
                <div class="empty-cart-container">
                    <i class="fa-solid fa-cart-shopping" style="font-size: 80px; color: #ddd; margin-bottom: 20px;"></i>
                    <h1 style="color: #999;">Giỏ hàng của bạn đang trống</h1>
                    <a href="index.php" style="text-decoration:none; background:#151534; color:white; padding:12px 25px; border-radius:5px;">Quay lại cửa hàng</a>
                </div>`;
            return;
        }

        let html = "";
        items.forEach(item => {
            html += `
                <tr>
                    <td><img src="admin/img/${item.anh}" width="70px" height="70px" style="object-fit:cover; border-radius:5px;"></td>
                    <td>
                        <a style="color:#151534; font-weight:500; text-decoration:none;" href="xemChiTietSP.php?id=${item.id_san_pham}">
                            ${item.ten}
                        </a>
                    </td>
                    <td style="text-align:center; font-weight:bold;">${item.so_luong}</td>
                    <td style="color:#333;">${Number(item.thanh_tien).toLocaleString('vi-VN')} VNĐ</td>
                    <td>
                        <button onclick="removeItem(${item.id_san_pham})" class="btn-delete">
                            <i class="fa-solid fa-trash-can"></i> Xóa
                        </button>
                    </td>
                </tr>`;
        });
        
        tableBody.innerHTML = html;
        totalDisplay.innerText = Number(total).toLocaleString('vi-VN') + " VNĐ";
    }

    function removeItem(productId) {
        if (!confirm('Bạn có chắc muốn xóa sản phẩm này?')) return;

        fetch('api_delete_item.php', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ idsp: productId, idgh: currentCartId })
        })
        .then(res => res.json())
        .then(data => {
            if (data.status === 'success') {
                loadCart(); // Tải lại bảng dữ liệu ngầm
            } else {
                alert("Lỗi: " + data.message);
            }
        })
        .catch(err => alert("Lỗi kết nối server!"));
    }
    </script>

