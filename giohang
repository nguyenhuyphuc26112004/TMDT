require('php/client/getObjectById.php');

// 2. Lấy ID sản phẩm từ URL
if(isset($_GET['id'])) {
    $idSP = $_GET['id'];
    $sanPham = getObjectById($con, 'san_pham', $idSP);

    // --- ĐOẠN CODE AI: GHI NHỚ LỊCH SỬ XEM ---
    if (!isset($_SESSION['viewed_history'])) {
        $_SESSION['viewed_history'] = array();
    }
    // Nếu ID này chưa có trong lịch sử, đưa nó lên đầu mảng
    if (!in_array($idSP, $_SESSION['viewed_history'])) {
        array_unshift($_SESSION['viewed_history'], $idSP);
    } else {
        // Nếu đã có, đưa nó lên đầu lại để tính là "vừa xem nhất"
        $key = array_search($idSP, $_SESSION['viewed_history']);
        unset($_SESSION['viewed_history'][$key]);
        array_unshift($_SESSION['viewed_history'], $idSP);
    }
    // Chỉ giữ tối đa 10 sản phẩm gần nhất để nhẹ bộ nhớ
    $_SESSION['viewed_history'] = array_slice($_SESSION['viewed_history'], 0, 10);
    // ------------------------------------------
} else {
    header("Location: trangchu.php");
    exit();
}
